nextflow.enable.dsl = 2

manifest {
    name        = 'TrESFlow'
    description = 'Thin Nextflow DSL2 wrappers for the upstream TrES source scripts'
    version     = '0.1.0'
}

params {
    outdir       = "${projectDir}/results"
    samplesheet  = null
    upstream_dir = "${projectDir}/upstream/source_scripts"
    runtime_env_prefix = '/home/annan/micromamba/envs/tres'
    runtime_python = '/home/annan/micromamba/envs/tres/bin/python3'
    runtime_trim_galore = '/home/annan/micromamba/envs/tres/bin/trim_galore'
    runtime_star = '/home/annan/micromamba/envs/tres/bin/STAR'
    runtime_samtools = '/home/annan/micromamba/envs/tres/bin/samtools'
    runtime_bedgraph_to_bigwig = '/home/annan/micromamba/envs/tres/bin/bedGraphToBigWig'
    runtime_bwa_mem2 = '/home/annan/micromamba/envs/tres/bin/bwa-mem2'
    runtime_bam_coverage = '/home/annan/micromamba/envs/tres/bin/bamCoverage'
    gatk_root = '/mnt/dataFast/ahrmad/gatk-4.6.0.0'
    rna_ref_base_dir = null
    rna_align_species = null
    dna_bwa_reference = null
    dna_blacklist_bed = null
    dna_effective_genome_size = null
    max_cpus = 40
}

profiles {
    standard {
        includeConfig 'conf/base.config'
    }
    test {
        includeConfig 'conf/base.config'
        includeConfig 'conf/test.config'
    }
    test_dna {
        includeConfig 'conf/base.config'
        includeConfig 'conf/test_dna.config'
    }
    test_multiome {
        includeConfig 'conf/base.config'
        includeConfig 'conf/test_multiome.config'
    }
    test_real_rna {
        includeConfig 'conf/base.config'
        includeConfig 'conf/test_real_rna.config'
    }
    conda_dev {
        includeConfig 'conf/conda_dev.config'
    }
    docker {
        includeConfig 'conf/docker.config'
    }
}
