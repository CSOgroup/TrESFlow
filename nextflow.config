nextflow.enable.dsl = 2

manifest {
    name        = 'TrESFlow'
    description = 'Thin Nextflow DSL2 wrappers for the upstream TrES source scripts'
    version     = '0.1.0'
}

params {
    outdir       = "${projectDir}/results"
    samplesheet  = null

    // Repo-owned core runtime scripts
    core_scripts_dir = "${projectDir}/scripts/core_runtime"

    // Optional downstream entrypoint kept separate from the core path
    optional_sc_process_script = "${projectDir}/upstream/source_scripts/sc_process.py"

    // Explicit executable bindings
    runtime_bin_dir = '/home/annan/micromamba/envs/tres/bin'
    runtime_python = "${params.runtime_bin_dir}/python3"
    runtime_trim_galore = "${params.runtime_bin_dir}/trim_galore"
    runtime_star = "${params.runtime_bin_dir}/STAR"
    runtime_samtools = "${params.runtime_bin_dir}/samtools"
    runtime_bedgraph_to_bigwig = "${params.runtime_bin_dir}/bedGraphToBigWig"
    runtime_bwa_mem2 = "${params.runtime_bin_dir}/bwa-mem2"
    runtime_bam_coverage = "${params.runtime_bin_dir}/bamCoverage"
    runtime_gatk = "${params.runtime_bin_dir}/gatk"
    runtime_snap_data_dir = '/home/annan/.cache/snapatac2'
    runtime_codon = '/home/annan/.codon/bin/codon'
    codon_home = '/home/annan/.codon'

    // Explicit static resource params
    rna_ref_base_dir = null
    rna_align_species = null
    dna_bwa_reference = null
    dna_blacklist_bed = null
    dna_effective_genome_size = null

    // Optional downstream toggles
    stage_sc_process_inputs = false
    run_sc_process = false

    // Executor budget
    max_cpus = 40
}

profiles {
    standard {
        includeConfig 'conf/base.config'
    }
    test {
        includeConfig 'conf/base.config'
        includeConfig 'conf/test.config'
    }
    test_real_rna {
        includeConfig 'conf/base.config'
        includeConfig 'conf/test_real_rna.config'
    }
    conda_dev {
        includeConfig 'conf/conda_dev.config'
    }
    docker {
        includeConfig 'conf/docker.config'
    }
}
