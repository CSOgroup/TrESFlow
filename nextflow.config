nextflow.enable.dsl = 2

manifest {
    name        = 'TrESFlow'
    description = 'Thin Nextflow DSL2 wrappers for the upstream TrES source scripts'
    version     = '0.1.0'
}

params {
    outdir       = "${projectDir}/results"
    samplesheet  = null

    // Repo-owned core runtime scripts
    core_scripts_dir = "${projectDir}/scripts/core_runtime"

    // Optional downstream entrypoint kept separate from the core path
    optional_sc_process_script = "${projectDir}/upstream/source_scripts/sc_process.py"

    // Main runtime environment root; standard executables are derived from <prefix>/bin
    runtime_env_prefix = '/home/annan/micromamba/envs/tres'
    runtime_snap_data_dir = '/home/annan/.cache/snapatac2'

    // Explicit exceptions that are not currently env-based on this server
    runtime_codon = '/home/annan/.codon/bin/codon'
    codon_home = '/home/annan/.codon'

    // Shared run-resource fallbacks when the YAML samplesheet omits them
    ligation_barcode_whitelist = "${projectDir}/assets/test_realdata/ligation_barcode_whitelist.txt"
    rna_ref_base_dir = null
    rna_align_species = null
    dna_bwa_reference = null
    dna_blacklist_bed = null
    dna_effective_genome_size = null

    // Barcode defaults kept out of the user-facing YAML contract
    barcode_defaults = [
        rna: [
            sample: [
                bc_len            : 4,
                bc_start          : 0,
                hd                : 1,
                tag               : 'SB',
                first_pass        : 'first_pass',
                reverse_complement: true,
            ],
            umi: [
                bc_len  : 10,
                bc_start: 4,
                tag     : 'UM',
            ],
            cell: [
                bc_len: 8,
                hd    : 1,
                tag   : 'CB',
            ],
        ],
        dna: [
            sample: [
                bc_len            : 4,
                bc_start          : 14,
                hd                : 1,
                tag               : 'SB',
                first_pass        : 'first_pass',
                reverse_complement: true,
            ],
            modality: [
                bc_len            : 8,
                bc_start          : 18,
                hd                : 1,
                tag               : 'MO',
                first_pass        : 'not_first_pass',
                reverse_complement: true,
            ],
            cell: [
                bc_len: 8,
                hd    : 1,
                tag   : 'CB',
            ],
        ],
    ]

    // Optional downstream toggles
    stage_sc_process_inputs = false
    run_sc_process = false

    // Executor budget
    max_cpus = 40
}

profiles {
    standard {
        includeConfig 'conf/base.config'
    }
    test {
        includeConfig 'conf/base.config'
        includeConfig 'conf/test.config'
    }
    test_real_rna {
        includeConfig 'conf/base.config'
        includeConfig 'conf/test_real_rna.config'
    }
    conda_dev {
        includeConfig 'conf/conda_dev.config'
    }
    docker {
        includeConfig 'conf/docker.config'
    }
}
