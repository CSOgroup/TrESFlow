nextflow_pipeline {

    name "TrESFlow RNA smoke test"
    script "../main.nf"
    tag "pipeline"

    test("-profile test") {

        when {
            params {
                outdir = "$outputDir"
            }
        }

        then {
            def sampleId = "test_rna"
            // versions.yml snapshot placeholder retained for nf-core lint compatibility.

            def splitDir = new File(outputDir, "rna_split_fastqs")
            def alignDir = new File(outputDir, "rna_align")
            def statsDir = new File(outputDir, "TrES_Stats")
            def pipelineInfoDir = new File(outputDir, "pipeline_info")

            assertAll(
                { assert workflow.success },
                { assert new File(splitDir, "${sampleId}_Normal_R1.fastq.gz").exists() },
                { assert new File(splitDir, "${sampleId}_Co2_R2.fastq.gz").exists() },
                { assert !splitDir.listFiles().any { it.name.startsWith("SAM_RG_Header") } },
                { assert new File(alignDir, "${sampleId}_Normal.Solo.outGeneFull/filtered/matrix.mtx").exists() },
                { assert new File(alignDir, "${sampleId}_Normal.filtered_cells.bam").exists() },
                { assert new File(statsDir, "${sampleId}.rna_sample_barcode.counts.tsv").exists() },
                { assert new File(statsDir, "${sampleId}.rna_sample_barcode.stats.tsv").exists() },
                { assert new File(statsDir, "${sampleId}.rna_umi.counts.tsv").exists() },
                { assert new File(statsDir, "${sampleId}.rna_cell.counts.tsv").exists() },
                { assert new File(statsDir, "${sampleId}.rna_cell.stats_L1.tsv").exists() },
                { assert new File(statsDir, "${sampleId}.rna_cell.stats_L2.tsv").exists() },
                { assert new File(statsDir, "${sampleId}.rna_cell.stats_L3.tsv").exists() },
                { assert new File(statsDir, "${sampleId}.rna_tag_records.tsv.gz").exists() },
                { assert !statsDir.listFiles().any { it.name.contains(".sankey.") } },
                { assert !statsDir.listFiles().any { it.name.endsWith(".upset.html") } },
                { assert !statsDir.listFiles().any { it.name.endsWith("tag_records.tsv") } },
                { assert new File(pipelineInfoDir, "runtime_contract.tsv").exists() }
            )
        }
    }

    test("missing runtime.env_prefix fails") {

        when {
            params {
                samplesheet = "$projectDir/tests/samplesheets/missing_runtime_env_prefix.yaml"
                outdir = "$outputDir"
            }
        }

        then {
            def output = (workflow.stdout + workflow.stderr).join('\n')
            assertAll(
                { assert !workflow.success },
                { assert output.contains("Missing required field: runtime.env_prefix") }
            )
        }
    }

    test("cleanup_work false keeps pipeline success and published outputs") {

        when {
            params {
                outdir = "$outputDir"
                cleanup_work = false
            }
        }

        then {
            def sampleId = "test_rna"
            def splitDir = new File(outputDir, "rna_split_fastqs")
            def statsDir = new File(outputDir, "TrES_Stats")

            assertAll(
                { assert workflow.success },
                { assert new File(splitDir, "${sampleId}_Normal_R1.fastq.gz").exists() },
                { assert new File(statsDir, "${sampleId}.rna_tag_records.tsv.gz").exists() }
            )
        }
    }

    test("missing runtime.tmpdir defaults to outdir") {

        when {
            params {
                samplesheet = "$projectDir/tests/samplesheets/missing_runtime_tmpdir.yaml"
                outdir = "$outputDir"
            }
        }

        then {
            def runtimeContract = new File(outputDir, "pipeline_info/runtime_contract.tsv")
            assertAll(
                { assert workflow.success },
                { assert runtimeContract.exists() },
                { assert runtimeContract.text.contains("runtime_tmpdir\t${outputDir}") }
            )
        }
    }

    test("explicit runtime.tmpdir is preserved") {

        when {
            params {
                samplesheet = "$projectDir/tests/samplesheets/explicit_runtime_tmpdir.yaml"
                outdir = "$outputDir"
            }
        }

        then {
            def runtimeContract = new File(outputDir, "pipeline_info/runtime_contract.tsv")
            assertAll(
                { assert workflow.success },
                { assert runtimeContract.exists() },
                { assert runtimeContract.text.contains("runtime_tmpdir\t/tmp/TrESFlow_explicit_runtime_tmpdir") }
            )
        }
    }

    test("missing references.root fails") {

        when {
            params {
                samplesheet = "$projectDir/tests/samplesheets/missing_references_root.yaml"
                outdir = "$outputDir"
            }
        }

        then {
            def output = (workflow.stdout + workflow.stderr).join('\n')
            assertAll(
                { assert !workflow.success },
                { assert output.contains("Missing required field: references.root") }
            )
        }
    }

    test("deprecated runtime_env_prefix param fails") {

        when {
            params {
                samplesheet = "$projectDir/assets/samplesheet.example.yaml"
                outdir = "$outputDir"
                runtime_env_prefix = "/tmp/legacy-env"
            }
        }

        then {
            def output = (workflow.stdout + workflow.stderr).join('\n')
            assertAll(
                { assert !workflow.success },
                { assert output.contains("Deprecated parameter --runtime_env_prefix is no longer supported") }
            )
        }
    }

    test("missing ligation whitelist does not fall back to test assets") {

        when {
            params {
                samplesheet = "$projectDir/tests/samplesheets/missing_ligation_whitelist.yaml"
                outdir = "$outputDir"
            }
        }

        then {
            def output = (workflow.stdout + workflow.stderr).join('\n')
            assertAll(
                { assert !workflow.success },
                { assert output.contains("Required ligation barcode whitelist not found") },
                { assert output.contains("references.ligation_barcode_whitelist") }
            )
        }
    }

    test("missing bwa-mem2 sidecar fails before DNA execution") {

        when {
            params {
                samplesheet = "$projectDir/tests/samplesheets/missing_bwa_sidecar.yaml"
                outdir = "$outputDir"
            }
        }

        then {
            def output = (workflow.stdout + workflow.stderr).join('\n')
            assertAll(
                { assert !workflow.success },
                { assert output.contains("No complete bwa-mem2 sidecar set found in references.dna_ref_dir") },
                { assert output.contains("hg38.fa.bwt.2bit.64") }
            )
        }
    }

    test("dual tagmentation without dna.reads.i2 runs and publishes DNA stats to TrES_Stats") {

        when {
            params {
                samplesheet = "$projectDir/tests/samplesheets/dual_without_i2.yaml"
                outdir = "$outputDir"
            }
        }

        then {
            def sampleId = "dual_no_i2"
            def splitName = "${sampleId}_Normal_H3K27ac"
            def splitDir = new File(outputDir, "dna_split_fastqs")
            def alignDir = new File(outputDir, "dna_align")
            def statsDir = new File(outputDir, "TrES_Stats")
            def tagRecords = new java.util.zip.GZIPInputStream(
                new FileInputStream(new File(statsDir, "${sampleId}.dna_tag_records.tsv.gz"))
            ).getText("UTF-8")

            assertAll(
                { assert workflow.success },
                { assert new File(splitDir, "${splitName}_R1.fastq.gz").exists() },
                { assert new File(alignDir, "${splitName}_MarkedDup.bam").exists() },
                { assert new File(alignDir, "${splitName}_MarkedDup.bam.bai").exists() },
                { assert new File(alignDir, "${splitName}_NoDup.bam").exists() },
                { assert new File(alignDir, "${splitName}_NoDup.bam.bai").exists() },
                { assert new File(alignDir, "${splitName}_NoDup.bw").exists() },
                { assert !new File(statsDir, "${splitName}_ProperPairedMapped_reads_per_barcode.tsv").exists() },
                { assert !new File(alignDir, "${splitName}_ProperPairedMapped_reads_per_barcode.tsv").exists() },
                { assert !statsDir.listFiles().any { it.name.contains(".sankey.") } },
                { assert !statsDir.listFiles().any { it.name.endsWith(".upset.html") } },
                { assert tagRecords.contains("CB:Z:AAAACGTACGTTGCATGCAGATCGATC") },
                { assert tagRecords.contains("L1:Z:ACGTACGT") },
                { assert tagRecords.contains("L2:Z:TGCATGCA") },
                { assert tagRecords.contains("L3:Z:GATCGATC") },
                { assert tagRecords.contains("SB:Z:AAA") },
                { assert tagRecords.contains("MO:Z:AGGCTATA") }
            )
        }
    }

    test("single tagmentation with dna.reads.i2 runs") {

        when {
            params {
                samplesheet = "$projectDir/tests/samplesheets/single_with_i2.yaml"
                outdir = "$outputDir"
            }
        }

        then {
            def sampleId = "single_with_i2"
            def splitName = "${sampleId}_Normal_H3K27ac"
            def splitDir = new File(outputDir, "dna_split_fastqs")
            def alignDir = new File(outputDir, "dna_align")
            def statsDir = new File(outputDir, "TrES_Stats")
            def tagRecords = new java.util.zip.GZIPInputStream(
                new FileInputStream(new File(statsDir, "${sampleId}.dna_tag_records.tsv.gz"))
            ).getText("UTF-8")

            assertAll(
                { assert workflow.success },
                { assert new File(splitDir, "${splitName}_R1.fastq.gz").exists() },
                { assert new File(alignDir, "${splitName}_MarkedDup.bam").exists() },
                { assert new File(statsDir, "${sampleId}.dna_tag_records.tsv.gz").exists() },
                { assert tagRecords.contains("SB:Z:CGTA") },
                { assert tagRecords.contains("MO:Z:TTTACGTA") }
            )
        }
    }

    test("single tagmentation without dna.reads.i2 fails") {

        when {
            params {
                samplesheet = "$projectDir/tests/samplesheets/single_missing_i2.yaml"
                outdir = "$outputDir"
            }
        }

        then {
            def output = (workflow.stdout + workflow.stderr).join('\n')
            assertAll(
                { assert !workflow.success },
                { assert output.contains("Missing required field: samples.single_missing_i2.dna.reads.i2") }
            )
        }
    }

    test("missing rna_ref_dir fails when RNA is present") {

        when {
            params {
                samplesheet = "$projectDir/tests/samplesheets/missing_rna_ref_dir.yaml"
                outdir = "$outputDir"
            }
        }

        then {
            def output = (workflow.stdout + workflow.stderr).join('\n')
            assertAll(
                { assert !workflow.success },
                { assert output.contains("Missing required field: references.rna_ref_dir") }
            )
        }
    }

    test("missing STAR index file fails") {

        when {
            params {
                samplesheet = "$projectDir/tests/samplesheets/missing_star_index_file.yaml"
                outdir = "$outputDir"
            }
        }

        then {
            def output = (workflow.stdout + workflow.stderr).join('\n')
            assertAll(
                { assert !workflow.success },
                { assert output.contains("RNA STAR index file missing for references.rna_ref_dir") },
                { assert output.contains("SAindex") }
            )
        }
    }

    test("dual tagmentation without dna_sb_barcodes fails") {

        when {
            params {
                samplesheet = "$projectDir/tests/samplesheets/dual_missing_dna_sb.yaml"
                outdir = "$outputDir"
            }
        }

        then {
            def output = (workflow.stdout + workflow.stderr).join('\n')
            assertAll(
                { assert !workflow.success },
                { assert output.contains("DNA dual tagmentation requires explicit 3 nt dna_sb_barcodes") }
            )
        }
    }

    test("dual tagmentation duplicate DNA sample barcode fails") {

        when {
            params {
                samplesheet = "$projectDir/tests/samplesheets/dual_duplicate_dna_sb.yaml"
                outdir = "$outputDir"
            }
        }

        then {
            def output = (workflow.stdout + workflow.stderr).join('\n')
            assertAll(
                { assert !workflow.success },
                { assert output.contains("DNA sample barcode collision") },
                { assert output.contains("AAA") }
            )
        }
    }
}
