nextflow_pipeline {

    name "TrESFlow RNA smoke test"
    script "../main.nf"
    tag "pipeline"

    test("-profile test") {

        when {
            params {
                outdir = "$outputDir"
            }
        }

        then {
            def sampleId = "test_rna"
            // versions.yml snapshot placeholder retained for nf-core lint compatibility.

            def splitDir = new File(outputDir, "split")
            def alignDir = new File(outputDir, "align")
            def pipelineInfoDir = new File(outputDir, "pipeline_info")

            assertAll(
                { assert workflow.success },
                { assert new File(splitDir, "${sampleId}_Normal_R1.fq.gz").exists() },
                { assert new File(splitDir, "${sampleId}_Co2_R2.fq.gz").exists() },
                { assert new File(alignDir, "${sampleId}_Normal.Solo.outGeneFull/filtered/matrix.mtx").exists() },
                { assert new File(alignDir, "${sampleId}_Normal.filtered_cells.bam").exists() },
                { assert new File(pipelineInfoDir, "runtime_contract.tsv").exists() }
            )
        }
    }

    test("missing runtime.env_prefix fails") {

        when {
            params {
                samplesheet = "$projectDir/tests/samplesheets/missing_runtime_env_prefix.yaml"
                outdir = "$outputDir"
            }
        }

        then {
            assertAll(
                { assert !workflow.success },
                { assert workflow.stderr.contains("Missing required field: runtime.env_prefix") }
            )
        }
    }

    test("missing runtime.tmpdir fails") {

        when {
            params {
                samplesheet = "$projectDir/tests/samplesheets/missing_runtime_tmpdir.yaml"
                outdir = "$outputDir"
            }
        }

        then {
            assertAll(
                { assert !workflow.success },
                { assert workflow.stderr.contains("Missing required field: runtime.tmpdir") }
            )
        }
    }

    test("missing references.root fails") {

        when {
            params {
                samplesheet = "$projectDir/tests/samplesheets/missing_references_root.yaml"
                outdir = "$outputDir"
            }
        }

        then {
            assertAll(
                { assert !workflow.success },
                { assert workflow.stderr.contains("Missing required field: references.root") }
            )
        }
    }

    test("deprecated runtime_env_prefix param fails") {

        when {
            params {
                samplesheet = "$projectDir/assets/samplesheet.example.yaml"
                outdir = "$outputDir"
                runtime_env_prefix = "/tmp/legacy-env"
            }
        }

        then {
            assertAll(
                { assert !workflow.success },
                { assert workflow.stderr.contains("Deprecated parameter --runtime_env_prefix is no longer supported") }
            )
        }
    }

    test("missing ligation whitelist does not fall back to test assets") {

        when {
            params {
                samplesheet = "$projectDir/tests/samplesheets/missing_ligation_whitelist.yaml"
                outdir = "$outputDir"
            }
        }

        then {
            assertAll(
                { assert !workflow.success },
                { assert workflow.stderr.contains("Required ligation barcode whitelist not found") },
                { assert workflow.stderr.contains("Expected <references.root>/ligation_barcode_whitelist.txt") }
            )
        }
    }

    test("missing bwa-mem2 sidecar fails before DNA execution") {

        when {
            params {
                samplesheet = "$projectDir/tests/samplesheets/missing_bwa_sidecar.yaml"
                outdir = "$outputDir"
            }
        }

        then {
            assertAll(
                { assert !workflow.success },
                { assert workflow.stderr.contains("DNA bwa-mem2 index sidecar not found") },
                { assert workflow.stderr.contains("Controlled by samplesheet field references.root") }
            )
        }
    }
}
