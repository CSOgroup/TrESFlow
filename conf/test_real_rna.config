/*
 * Optional external/local real-RNA validation profile.
 * This keeps the current RNA-only workflow in real mode through AlignRNA.sh and is intended for tiny local datasets.
 * It does not set a default samplesheet, because the real validation data is expected to live outside the repo.
 * Real runs must still provide --rna_ref_base_dir and --rna_align_species explicitly.
 */

params {
    outdir = "${projectDir}/results/test_real_rna"
}
