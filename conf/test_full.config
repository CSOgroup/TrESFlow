/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Nextflow config file for running full-size tests
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Defines a repository-local full-size style regression profile.

    Use as follows:
        nextflow run . -profile test_full --samplesheet assets/samplesheet.real.example.yaml --outdir <OUTDIR>

----------------------------------------------------------------------------------------
*/

params {
    config_profile_name        = 'Full test profile'
    config_profile_description = 'Repository-local TrES full-size style regression profile'
    samplesheet                = "${projectDir}/assets/samplesheet.real.example.yaml"
    outdir                     = "${projectDir}/results/test_full"
}
