/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Config file for defining optional DSL2 per-module overrides
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    TrESFlow currently handles most publish locations directly inside local modules.
    This file is intentionally minimal to satisfy nf-core repository structure
    without changing the validated scientific runtime contract.
----------------------------------------------------------------------------------------
*/

process {
    publishDir = [
        mode: params.publish_dir_mode
    ]
}
