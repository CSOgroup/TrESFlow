params {
    samplesheet = "${projectDir}/assets/samplesheet.dna.example.yaml"
    outdir      = "${projectDir}/results/test_dna"
    max_cpus    = 4
}

process {
    withName: TAG_DNA_SAMPLE_BARCODE {
        ext.mock = true
    }

    withName: TAG_DNA_MODALITY_BARCODE {
        ext.mock = true
    }

    withName: TAG_DNA_CELL_BARCODE {
        ext.mock = true
    }

    withName: TRIM_DNA_FASTQS {
        ext.mock = true
    }

    withName: SPLIT_DNA_READS {
        ext.mock = true
    }
}
