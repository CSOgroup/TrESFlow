executor {
    cpus = params.max_cpus as int
}

process {
    executor = 'local'
    shell    = ['/bin/bash', '-euo', 'pipefail']
    cpus     = 1
    memory   = '1 GB'
    time     = '1h'

    // Scheduler reservations keep RNA and DNA able to overlap on a 64-core host.

    withName: TAG_RNA_SAMPLE_BARCODE {
        cpus = 6
        memory = 64.GB
        time = '6h'
    }

    withName: TAG_DNA_SAMPLE_BARCODE {
        cpus = 6
        memory = 64.GB
        time = '6h'
    }

    withName: TAG_RNA_UMI {
        cpus = 6
        memory = 64.GB
        time = '6h'
    }

    withName: TAG_DNA_MODALITY_BARCODE {
        cpus = 6
        memory = 64.GB
        time = '6h'
    }

    withName: TAG_RNA_CELL_BARCODE {
        cpus = 6
        memory = 64.GB
        time = '6h'
    }

    withName: TAG_DNA_CELL_BARCODE {
        cpus = 6
        memory = 64.GB
        time = '6h'
    }

    withName: TRIM_RNA_FASTQS {
        cpus = Math.max(1, Math.min(16, (params.max_cpus as int).intdiv(4)))
        time = '2h'
    }

    withName: TRIM_DNA_FASTQS {
        cpus = Math.max(1, Math.min(16, (params.max_cpus as int).intdiv(4)))
        time = '2h'
    }

    withName: SPLIT_RNA_READS {
        cpus = Math.max(1, Math.min(16, (params.max_cpus as int).intdiv(4)))
        time = '2h'
    }

    withName: SPLIT_DNA_READS {
        cpus = Math.max(1, Math.min(16, (params.max_cpus as int).intdiv(4)))
        time = '2h'
    }

    withName: FQ_TO_SAM {
        cpus = 1
    }

    withName: RNA_STARSOLO_ALIGN {
        cpus = Math.max(1, Math.min(48, params.max_cpus as int))
        time = '12h'
    }

    withName: RNA_FILTERED_BAM {
        cpus = Math.max(1, Math.min(16, (params.max_cpus as int).intdiv(4)))
        time = '2h'
    }

    withName: RNA_COVERAGE {
        cpus = Math.max(1, Math.min(32, params.max_cpus as int))
        time = '12h'
    }

    // ALIGN_DNA passes this CPU value to bwa-mem2 and samtools inside the wrapper.
    withName: ALIGN_DNA {
        cpus = Math.max(1, Math.min(48, params.max_cpus as int))
        time = '12h'
    }

    withName: MARK_DUPLICATES_DNA {
        cpus = 1
        memory = '8 GB'
        time = '6h'
    }

    withName: SPLIT_DUPLICATES_DNA {
        cpus = Math.max(1, Math.min(16, (params.max_cpus as int).intdiv(4)))
        memory = '4 GB'
        time = '2h'
    }

    withName: BAM_COVERAGE_DNA {
        cpus = Math.max(1, Math.min(32, params.max_cpus as int))
        memory = '4 GB'
        time = '2h'
    }

    withName: SEQUENCING_EFFICIENCY {
        cpus = 1
        memory = '4 GB'
        time = '2h'
    }

}

timeline {
    enabled   = true
    file      = "${params.outdir ?: "${projectDir}/results"}/pipeline_info/execution_timeline.html"
    overwrite = true
}

report {
    enabled   = true
    file      = "${params.outdir ?: "${projectDir}/results"}/pipeline_info/execution_report.html"
    overwrite = true
}

trace {
    enabled   = true
    file      = "${params.outdir ?: "${projectDir}/results"}/pipeline_info/execution_trace.tsv"
    overwrite = true
}

dag {
    enabled   = true
    file      = "${params.outdir ?: "${projectDir}/results"}/pipeline_info/flowchart.html"
    overwrite = true
}
