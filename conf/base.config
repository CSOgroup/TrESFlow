executor {
    cpus = params.max_cpus as int
}

process {
    executor = 'local'
    shell    = ['/bin/bash', '-euo', 'pipefail']
    cpus     = 1
    memory   = '1 GB'
    time     = '1h'
    beforeScript = """
    export RUNTIME_ENV_PREFIX="${params.runtime_env_prefix}"
    export RUNTIME_BIN_DIR="${params.runtime_env_prefix}/bin"
    export PYTHON3_BIN="${params.runtime_env_prefix}/bin/python3"
    export TRIM_GALORE_BIN="${params.runtime_env_prefix}/bin/trim_galore"
    export STAR_BIN="${params.runtime_env_prefix}/bin/STAR"
    export SAMTOOLS_BIN="${params.runtime_env_prefix}/bin/samtools"
    export BEDGRAPH_TO_BIGWIG_BIN="${params.runtime_env_prefix}/bin/bedGraphToBigWig"
    export BWA_MEM2_BIN="${params.runtime_env_prefix}/bin/bwa-mem2"
    export BAMCOVERAGE_BIN="${params.runtime_env_prefix}/bin/bamCoverage"
    export GATK_BIN="${params.runtime_env_prefix}/bin/gatk"
    export CODON_BIN="${params.runtime_env_prefix}/bin/codon"
    export CODON_HOME="${params.runtime_env_prefix}"
    """

    // Scheduler reservations keep RNA and DNA able to overlap on a 64-core host.

    withName: TAG_RNA_SAMPLE_BARCODE {
        cpus = 1
        time = '6h'
    }

    withName: TAG_DNA_SAMPLE_BARCODE {
        cpus = 1
        time = '6h'
    }

    withName: TAG_RNA_UMI {
        cpus = 1
        time = '6h'
    }

    withName: TAG_DNA_MODALITY_BARCODE {
        cpus = 1
        time = '6h'
    }

    withName: TAG_RNA_CELL_BARCODE {
        cpus = 1
        time = '6h'
    }

    withName: TAG_DNA_CELL_BARCODE {
        cpus = 1
        time = '6h'
    }

    withName: TRIM_RNA_FASTQS {
        cpus = Math.max(1, Math.min(8, (params.max_cpus as int).intdiv(8)))
        time = '2h'
    }

    withName: TRIM_DNA_FASTQS {
        cpus = Math.max(1, Math.min(8, (params.max_cpus as int).intdiv(8)))
        time = '2h'
    }

    withName: SPLIT_RNA_READS {
        cpus = Math.max(1, Math.min(8, (params.max_cpus as int).intdiv(8)))
        time = '2h'
    }

    withName: SPLIT_DNA_READS {
        cpus = Math.max(1, Math.min(8, (params.max_cpus as int).intdiv(8)))
        time = '2h'
    }

    withName: FQ_TO_SAM {
        cpus = 1
    }

    withName: RNA_STARSOLO_ALIGN {
        cpus = Math.max(1, Math.min(24, (params.max_cpus as int).intdiv(2)))
        time = '12h'
    }

    withName: RNA_FILTERED_BAM {
        cpus = Math.max(1, Math.min(8, (params.max_cpus as int).intdiv(8)))
        time = '2h'
    }

    withName: RNA_COVERAGE {
        cpus = Math.max(1, Math.min(24, (params.max_cpus as int).intdiv(2)))
        time = '12h'
    }

    // ALIGN_DNA still wraps an upstream script with its own thread choices;
    // this CPU value primarily controls local scheduler concurrency.
    withName: ALIGN_DNA {
        cpus = Math.max(1, Math.min(32, (params.max_cpus as int).intdiv(2)))
        time = '12h'
    }

    withName: MARK_DUPLICATES_DNA {
        cpus = 1
        memory = '8 GB'
        time = '6h'
    }

    withName: SPLIT_DUPLICATES_DNA {
        cpus = Math.max(1, Math.min(8, (params.max_cpus as int).intdiv(8)))
        memory = '4 GB'
        time = '2h'
    }

    withName: BAM_COVERAGE_DNA {
        cpus = Math.max(1, Math.min(8, (params.max_cpus as int).intdiv(8)))
        memory = '4 GB'
        time = '2h'
    }

    withName: RNA_QC {
        cpus = 1
        memory = '2 GB'
        time = '1h'
    }

    withName: DNA_QC {
        cpus = 1
        memory = '2 GB'
        time = '1h'
    }

}

timeline {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/execution_timeline.html"
    overwrite = true
}

report {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/execution_report.html"
    overwrite = true
}

trace {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/execution_trace.tsv"
    overwrite = true
}

dag {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/flowchart.html"
    overwrite = true
}
