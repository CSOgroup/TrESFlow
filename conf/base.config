executor {
    cpus = params.max_cpus as int
}

process {
    executor = 'local'
    shell    = ['/bin/bash', '-euo', 'pipefail']
    cpus     = 1
    memory   = '1 GB'
    time     = '1h'

    withName: TAG_RNA_SAMPLE_BARCODE {
        cpus = 1
    }

    withName: TAG_DNA_SAMPLE_BARCODE {
        cpus = 1
    }

    withName: TAG_RNA_UMI {
        cpus = 1
    }

    withName: TAG_DNA_MODALITY_BARCODE {
        cpus = 1
    }

    withName: TAG_RNA_CELL_BARCODE {
        cpus = 1
    }

    withName: TAG_DNA_CELL_BARCODE {
        cpus = 1
    }

    withName: TRIM_RNA_FASTQS {
        cpus = Math.max(1, Math.min(8, (params.max_cpus as int).intdiv(5)))
    }

    withName: TRIM_DNA_FASTQS {
        cpus = Math.max(1, Math.min(8, (params.max_cpus as int).intdiv(5)))
    }

    withName: SPLIT_RNA_READS {
        cpus = Math.max(1, Math.min(4, (params.max_cpus as int).intdiv(10)))
    }

    withName: SPLIT_DNA_READS {
        cpus = Math.max(1, Math.min(4, (params.max_cpus as int).intdiv(10)))
    }

    withName: FQ_TO_SAM {
        cpus = 1
    }

    withName: ALIGN_RNA {
        cpus = Math.max(1, (params.max_cpus as int).intdiv(2))
    }

    withName: ALIGN_DNA {
        cpus = Math.max(1, params.max_cpus as int)
    }
}

timeline {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/execution_timeline.html"
    overwrite = true
}

report {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/execution_report.html"
    overwrite = true
}

trace {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/execution_trace.tsv"
    overwrite = true
}

dag {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/flowchart.html"
    overwrite = true
}
