executor {
    cpus = params.max_cpus as int
}

process {
    executor = 'local'
    shell    = ['/bin/bash', '-euo', 'pipefail']
    cpus     = 1
    memory   = '1 GB'
    time     = '1h'
    beforeScript = """
    export PYTHON3_BIN="${params.runtime_python}"
    export TRIM_GALORE_BIN="${params.runtime_trim_galore}"
    export STAR_BIN="${params.runtime_star}"
    export SAMTOOLS_BIN="${params.runtime_samtools}"
    export BEDGRAPH_TO_BIGWIG_BIN="${params.runtime_bedgraph_to_bigwig}"
    export BWA_MEM2_BIN="${params.runtime_bwa_mem2}"
    export BAMCOVERAGE_BIN="${params.runtime_bam_coverage}"
    export GATK_BIN="${params.runtime_gatk}"
    export CODON_BIN="${params.runtime_codon}"
    export CODON_HOME="${params.codon_home}"
    """

    withName: TAG_RNA_SAMPLE_BARCODE {
        cpus = 1
    }

    withName: TAG_DNA_SAMPLE_BARCODE {
        cpus = 1
    }

    withName: TAG_RNA_UMI {
        cpus = 1
    }

    withName: TAG_DNA_MODALITY_BARCODE {
        cpus = 1
    }

    withName: TAG_RNA_CELL_BARCODE {
        cpus = 1
    }

    withName: TAG_DNA_CELL_BARCODE {
        cpus = 1
    }

    withName: TRIM_RNA_FASTQS {
        cpus = Math.max(1, Math.min(8, (params.max_cpus as int).intdiv(5)))
    }

    withName: TRIM_DNA_FASTQS {
        cpus = Math.max(1, Math.min(8, (params.max_cpus as int).intdiv(5)))
    }

    withName: SPLIT_RNA_READS {
        cpus = Math.max(1, Math.min(4, (params.max_cpus as int).intdiv(10)))
    }

    withName: SPLIT_DNA_READS {
        cpus = Math.max(1, Math.min(4, (params.max_cpus as int).intdiv(10)))
    }

    withName: FQ_TO_SAM {
        cpus = 1
    }

    withName: ALIGN_RNA {
        cpus = Math.max(1, (params.max_cpus as int).intdiv(2))
    }

    withName: ALIGN_DNA {
        cpus = Math.max(1, params.max_cpus as int)
    }

    withName: MARK_DUPLICATES_DNA {
        cpus = 1
        memory = '8 GB'
        time = '6h'
    }

    withName: SPLIT_DUPLICATES_DNA {
        cpus = Math.max(1, Math.min(4, (params.max_cpus as int).intdiv(10)))
        memory = '4 GB'
        time = '2h'
    }

    withName: BAM_COVERAGE_DNA {
        cpus = Math.max(1, Math.min(8, (params.max_cpus as int).intdiv(5)))
        memory = '4 GB'
        time = '2h'
    }

    withName: STAGE_SC_PROCESS_INPUTS {
        cpus = 1
        memory = '4 GB'
        time = '1h'
    }
}

timeline {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/execution_timeline.html"
    overwrite = true
}

report {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/execution_report.html"
    overwrite = true
}

trace {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/execution_trace.tsv"
    overwrite = true
}

dag {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/flowchart.html"
    overwrite = true
}
