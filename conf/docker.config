/*
 * Optional Docker profile.
 * Containerizes only the current Python wrapper steps.
 * This is the portable smoke-test path when composed with `test`.
 * It does not provision Codon or the Seq plugin for real non-mock execution.
 * Build the image first:
 *   docker build -f docker/first_slice.Dockerfile -t tresflow-first-slice:py312 .
 */

docker {
    enabled = true
}

process {
    withLabel: codon_wrapper {
        container = 'tresflow-first-slice:py312'
    }
}
