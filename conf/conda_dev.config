/*
 * Optional local-development profile.
 * Uses Nextflow's official conda integration and asks it to use micromamba.
 * This is intentionally not the default execution path.
 * It does not provision Codon or the Seq plugin.
 */

conda {
    enabled        = true
    useMicromamba  = true
}

process {
    withLabel: codon_wrapper {
        conda = "${projectDir}/envs/first_slice.yml"
    }
}
